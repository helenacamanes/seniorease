rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 🌟 Cada usuário só pode ler/escrever o PRÓPRIO documento e as PRÓPRIAS
    // tarefas. Sem isso, qualquer pessoa autenticada poderia ler ou alterar
    // dados (nome, e-mail, preferências, tarefas) de qualquer outro usuário.
    match /users/{userId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;
      // "create" acontece uma única vez, logo após o cadastro
      // (inicializarPerfilE_Tarefas), sempre com o próprio uid do novo usuário.
      allow create: if request.auth != null && request.auth.uid == userId;

      match /tasks/{taskId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // 🌟 Catálogo de cursos: qualquer usuário autenticado pode LER (para
    // saber o nome do curso e copiar as tarefas iniciais no cadastro), mas
    // NINGUÉM escreve pelo app cliente. Cursos são cadastrados via Firebase
    // Console/Admin SDK (script de seed), nunca direto do navegador/app.
    match /courses/{courseId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Bloqueia por padrão qualquer outra coleção não prevista acima.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
